  </data>
  <data name="Calibrate_Phase2Header" xml:space="preserve">
    <value>阶段 2: W={0}, 在 [{1}, {2}] 内扫描高度...</value>
  </data>
  <data name="Calibrate_Phase2Probe" xml:space="preserve">
    <value>阶段 2 (高): 试探 {0}x{1} ok={2}, 范围=[{3},{4}], n={5}</value>
  </data>
  <data name="Calibrate_Done" xml:space="preserve">
    <value>完成: {0}x{1} DIP 已应用 (最终 ok={2}). 边距: W={3}, H={4}. 试探次数: W={5}, H={6}.</value>
  </data>
  <data name="Calibrate_Error" xml:space="preserve">
    <value>错误: {0}: {1}</value>
  </data>

  <!-- ================ V2 Perf 仪表盘 ================ -->
  <!-- 监测 Rust GPU pump 性能。V2 路径下 readback 永远 0（GPU 全程），
       格式串只显示 render + 总帧 + peak，给 string.Format 多传的参数被忽略。
       avg_render_us 接近 16000us（60fps 阈值）时颜色由代码动态切换。 -->
  <data name="Header_Perf.Text" xml:space="preserve">
    <value>渲染管线性能</value>
  </data>
  <data name="Perf_Initial" xml:space="preserve">
    <value>等待采样中...</value>
  </data>
  <data name="Perf_Format" xml:space="preserve">
    <value>GPU {0} ms | C# {7} ms (rb {8} / cp {9}) | 滑窗 {3} | 总帧 {4} | peak GPU {5} / tick {10} ms | V3</value>
    <comment>Args: {0}=Rust 渲染均值ms {1}=Rust readback均值ms(V2=0) {2}=Rust 总均值ms {3}=滑窗有效样本数 {4}=Rust 总帧数 {5}=Rust GPU 峰值ms {6}=Rust readback 峰值ms {7}=C# tick 均值ms {8}=C# readback 均值ms {9}=C# copy 均值ms {10}=C# tick 峰值ms</comment>
  </data>
  <data name="Perf_FormatNoData" xml:space="preserve">
    <value>尚无帧（渲染器已创建但 pump 未启动）</value>
  </data>

