<Page
    x:Class="OverlayWidget.MainWidget"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:OverlayWidget"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{x:Null}"
    mc:Ignorable="d">

    <!--
        渲染区 + Root hover 显按钮（v0.6 DComp 路径）：
        - Root Grid Background="Transparent"：接收 hit-test，让 PointerEntered/Exited
          能在整个 widget 区域内触发；底层游戏 click 透传由 Game Bar host 在 pinned
          模式下自动屏蔽 widget hit-test
        - PlaceholderBg / Surface IsHitTestVisible=False：不接收 click，让事件冒泡到 Root
        - SettingsBtn 默认 Opacity=0；Root.PointerEntered fade 到 1.0；离开 widget 区域 fade 回 0

        渲染落点：CompositionPump 用 ElementCompositionPreview.SetElementChildVisual 把
        Rust swap chain 包成的 SpriteVisual 挂到 Surface 这个 Border 上。Border 默认会
        撑满父容器（Image 没 Source 时不会撑开，所以从 Image 改成 Border），spriteVisual.Size
        跟 Border.ActualSize 同步。SetElementChildVisual 的 visual 显示在 host element
        content 之下、host element 兄弟节点之上 —— 即 PlaceholderBg 之上、SettingsBtn 之下。

        历史 R3 阶段曾用 SwapChainPanel + ISwapChainPanelNative，被 widget host 跨进程
        代理拒绝该 native COM 接口；V1/V2 阶段 MediaPlayer + MediaStreamSource 内存泄漏；
        V3 Pinned + Image + WriteableBitmap modal 拖动期间 UI 线程冻结 wb.Invalidate 排队。
        v0.6 改成 DComp 让 DWM 内核合成器直接拉，绕开 XAML compositor。
    -->
    <Grid x:Name="Root"
          Background="Transparent"
          PointerEntered="OnRootPointerEntered"
          PointerExited="OnRootPointerExited">
        <!--
            第一层 (z-order 最低): 半透明灰占位
            - 启动时 / Rust 渲染没到来时显示，让 widget 不是黑乎乎一片
            - DComp visual 挂上后会在它之上，但 visual 内容 alpha < 1 时仍能透出底色
            - IsHitTestVisible=False：clicks 透传到底下
        -->
        <Border x:Name="PlaceholderBg"
                Background="#80606060"
                IsHitTestVisible="False" />

        <!--
            第二层: DComp visual 锚点。
            - 必须用 Border / Grid 等"块状"控件 —— Image 没 Source 时 ActualSize=0，
              CompositionPump 会把 spriteVisual.Size 设成 1x1，画面看不见
            - Border 默认 Stretch，会撑满 Root Grid，spriteVisual.Size 跟着 ActualSize
            - IsHitTestVisible=False：clicks 透传到底下
        -->
        <Border x:Name="Surface"
                IsHitTestVisible="False" />

        <!-- 齿轮按钮：默认 Opacity=0；hover 显示由 Root 监听触发，按钮自己不监听 -->
        <Button x:Name="SettingsBtn"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,8,8,0"
                Padding="10,6"
                MinWidth="0" MinHeight="0"
                Background="#A0000000"
                Foreground="White"
                BorderThickness="0"
                CornerRadius="4"
                FontFamily="Segoe MDL2 Assets"
                FontSize="18"
                Content="&#xE713;"
                Opacity="0">
            <Button.Resources>
                <Storyboard x:Name="FadeInStory">
                    <DoubleAnimation
                        Storyboard.TargetName="SettingsBtn"
                        Storyboard.TargetProperty="Opacity"
                        To="1.0" Duration="0:0:0.15" />
                </Storyboard>
                <Storyboard x:Name="FadeOutStory">
                    <DoubleAnimation
                        Storyboard.TargetName="SettingsBtn"
                        Storyboard.TargetProperty="Opacity"
                        To="0" Duration="0:0:0.30" />
                </Storyboard>
            </Button.Resources>
            <Button.Flyout>
                <Flyout Placement="Bottom">
                    <StackPanel Width="300" Spacing="10">
                        <TextBlock x:Uid="Header_Window"
                                   FontWeight="SemiBold"
                                   FontSize="13" />
                        <Button x:Uid="Button_Maximize"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Click="OnMaximize" />
                        <Button x:Uid="Button_Reset"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Click="OnRestoreDefault" />

                        <Border Height="1" Background="#40FFFFFF" Margin="0,4" />

                        <TextBlock x:Uid="Header_CustomResize"
                                   FontWeight="SemiBold"
                                   FontSize="13" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="28" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" x:Uid="Label_Width"  VerticalAlignment="Center" />
                            <TextBox   Grid.Column="1" x:Name="CustomW" Text="2560" InputScope="Number" />
                            <TextBlock Grid.Column="2" x:Uid="Label_Height" VerticalAlignment="Center" Margin="6,0,0,0" />
                            <TextBox   Grid.Column="3" x:Name="CustomH" Text="1440" InputScope="Number" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="6" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
                                    x:Uid="Button_Apply"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    Click="OnCustomApply" />
                            <Button Grid.Column="2"
                                    x:Name="ReadCurrentBtn"
                                    x:Uid="Button_ReadCurrent"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    Click="OnReadCurrent" />
                        </Grid>
                        <TextBlock x:Name="LastResult"
                                   FontSize="11"
                                   Opacity="0.8"
                                   TextWrapping="Wrap" />

                        <Border Height="1" Background="#40FFFFFF" Margin="0,4" />

                        <TextBlock x:Uid="Header_AutoCalibrate"
                                   FontWeight="SemiBold"
                                   FontSize="13" />
                        <TextBlock x:Uid="AutoCalibrate_Description"
                                   FontSize="10" Opacity="0.6" TextWrapping="Wrap" />
                        <Button x:Name="CalibrateBtn"
                                x:Uid="Button_Calibrate"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Click="OnCalibrate" />
                        <TextBlock x:Name="CalibrateProgress"
                                   FontSize="11" Opacity="0.8"
                                   TextWrapping="Wrap"
                                   Text="" />

                        <Border Height="1" Background="#40FFFFFF" Margin="0,4" />

                        <TextBlock x:Uid="Header_Perf"
                                   FontWeight="SemiBold"
                                   FontSize="13" />
                        <!-- PerfInfo: 1Hz 拉 renderer_get_perf_stats + BitmapRenderPump.GetPerfStats
                             显示 GPU 渲染 + C# tick (readback / copy) + 总帧 + peak。
                             文字颜色由 .xaml.cs 动态切换：avg_render_us 越靠近
                             16000us（60fps 阈值），颜色越偏黄/红 -->
                        <TextBlock x:Name="PerfInfo"
                                   FontSize="11"
                                   Opacity="0.85"
                                   TextWrapping="Wrap"
                                   IsTextSelectionEnabled="True" />

                        <Border Height="1" Background="#40FFFFFF" Margin="0,4" />

                        <TextBlock x:Uid="Header_Status"
                                   FontWeight="SemiBold"
                                   FontSize="13" />
                        <TextBlock x:Name="SizeInfo"
                                   FontSize="11"
                                   Opacity="0.8"
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="MaxInfo"
                                   FontSize="11"
                                   Opacity="0.8"
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="CalibratedInfo"
                                   FontSize="11"
                                   Opacity="0.8"
                                   TextWrapping="Wrap" />
                        <ScrollViewer MaxHeight="240"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="RendererInfo"
                                       FontSize="11"
                                       Opacity="0.8"
                                       TextWrapping="Wrap"
                                       IsTextSelectionEnabled="True" />
                        </ScrollViewer>

                        <Border Height="1" Background="#40FFFFFF" Margin="0,4" />

                        <!-- 阶段1：把上面所有诊断字段一次性拷到剪贴板，方便用户粘贴反馈 -->
                        <Button x:Name="CopyDiagBtn"
                                x:Uid="Button_CopyDiagnostics"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Click="OnCopyDiagnostics" />
                    </StackPanel>
                </Flyout>
            </Button.Flyout>
        </Button>
    </Grid>
</Page>
