    <AppxBundlePlatforms>x64</AppxBundlePlatforms>
    <HoursBetweenUpdateChecks>0</HoursBetweenUpdateChecks>
    <UapAppxPackageBuildMode>SideloadOnly</UapAppxPackageBuildMode>
    <!-- v0.6 DComp：CompositionPump 用 ICompositorInterop 把 Rust swap chain 包成
         ICompositionSurface 挂到 OS visual tree，绕开 XAML compositor。
         AllowUnsafeBlocks 给 Rust UTF-8 输入的 fixed byte* 路径用。 -->
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>
