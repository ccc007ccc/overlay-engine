  <!-- ============== 本地化资源（en-US / zh-CN） ==============
       系统会按用户首选语言自动选择 .resw；都缺失时 fallback 到第一个声明的语言。
       新增语言只需在 Strings\<lang-tag>\Resources.resw 放对应文件并加进这个 ItemGroup。 -->
  <ItemGroup>
    <PRIResource Include="Strings\en-US\Resources.resw" />
    <PRIResource Include="Strings\zh-CN\Resources.resw" />
  </ItemGroup>

  <!-- ============== Rust 渲染 DLL（C3 启用） ==============
       MSIX 包根会拷贝 renderer.dll，UWP 加载器查找规则会自动找到。
       要求：先在 workspace 根用 release profile 编过 renderer crate。
       cargo workspace 输出在 workspace root 的 target/，不再是 rust-renderer/target/
       （v0.6 单 crate 时是后者；自 v0.7 启用 workspace 后必须用前者）。 -->
  <ItemGroup>
    <Content Include="..\target\release\renderer.dll">
      <Link>renderer.dll</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

